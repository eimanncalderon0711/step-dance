model ScheduleDay {
  id    Int            @id @default(autoincrement())
  date  DateTime       @unique
  slots ScheduleSlot[]

  @@map("schedule_days")
}

model ScheduleSlot {
  id        Int         @id @default(autoincrement())
  capacity  Int
  booked    Int         @default(0)
  dayId     Int
  updatedAt DateTime    @updatedAt
  createdAt DateTime    @default(now())
  startTime DateTime
  endTime   DateTime
  location  String
  bookings  Booking[]
  day       ScheduleDay @relation(fields: [dayId], references: [id], onDelete: Cascade)

  @@map("schedule_slots")
}
