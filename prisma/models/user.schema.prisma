model User {
  id     Int     @id @default(autoincrement())
  email  String  @unique 
  name   String?
  posts  Post[]

  roleId Int
  role   Role @relation(fields: [roleId], references: [id])

  @@map("users")
}

model Role {
  id    Int    @id @default(autoincrement())
  name  String
  users User[]

  @@map("roles")
}