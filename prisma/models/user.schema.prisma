model User {
  id       Int       @id @default(autoincrement())
  supabaseId  String @unique  
  email    String    @unique
  name     String?
  roleId   Int
  bookings Booking[]
  posts    Post[]
  role     Role      @relation(fields: [roleId], references: [id])

  @@map("users")
}

model Role {
  id    Int    @id @default(autoincrement())
  name  String
  users User[]

  @@map("roles")
}
